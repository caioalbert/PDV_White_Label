# URL pooled do Neon, usada pela aplicacao em runtime.
DATABASE_URL=postgresql://usuario:senha@ep-exemplo-pooler.us-east-1.aws.neon.tech/pdv_carlos?sslmode=require

# URL direta do Neon, usada exclusivamente por migrations.
DATABASE_URL_UNPOOLED=postgresql://usuario:senha@ep-exemplo.us-east-1.aws.neon.tech/pdv_carlos?sslmode=require

# Gere um segredo aleatorio com pelo menos 32 caracteres.
JWT_SECRET=

# Opcional: somente para clientes hospedados em outra origem.
# O frontend e a API no mesmo projeto Vercel nao precisam desta variavel.
# CORS_ORIGINS=https://cliente-externo.example.com
