# Produção/Vercel: use a URL com pool fornecida pelo Neon.
DATABASE_URL=postgresql://usuario:senha@ep-exemplo-pooler.us-east-1.aws.neon.tech/pdv_carlos?sslmode=require
# Migrations devem usar a URL direta, sem PgBouncer.
DATABASE_URL_UNPOOLED=postgresql://usuario:senha@ep-exemplo.us-east-1.aws.neon.tech/pdv_carlos?sslmode=require

# Desenvolvimento local sem DATABASE_URL.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=pdv_carlos
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria
INITIAL_ADMIN_NAME=Administrador
INITIAL_ADMIN_LOGIN=admin
INITIAL_ADMIN_PASSWORD=
SEED_ADMIN_PASSWORD=
SEED_VENDOR_PASSWORD=
SEED_CASHIER_PASSWORD=
# Opcional: origens adicionais, separadas por virgula.
# O mesmo host e sempre permitido; nao use https://*.vercel.app.
CORS_ORIGINS=
PORT=3001
