{
  "name": "pdv-carlos-server",
  "version": "1.0.0",
  "description": "API do ERP Carlos Atacadão do Gesso",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "migrate": "node scripts/migrate.js latest",
    "migrate:status": "node scripts/migrate.js status",
    "seed": "npx knex seed:run --knexfile knexfile.js",
    "seed:dev": "ALLOW_DESTRUCTIVE_SEED=true npm run seed",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "setup": "npm run migrate",
    "setup:dev": "npm run migrate && npm run seed:dev",
    "bootstrap:admin": "node scripts/bootstrap-admin.js",
    "password:rotate": "node scripts/rotate-user-password.js",
    "users:provision-stores": "node scripts/provision-store-users.js",
    "products:import-client": "node scripts/import-client-products.js",
    "db:e2e:reset": "node scripts/reset-e2e-db.js",
    "start:e2e": "NODE_ENV=test DB_NAME=pdv_carlos_e2e PORT=3101 CORS_ORIGINS=http://127.0.0.1:5174 node index.js",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.13.0"
  }
}
